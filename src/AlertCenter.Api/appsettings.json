{
  "ConnectionStrings": {
    "AlertCenter": "Data Source=alertcenter.db"
  },
  "Feeds": {
    "Sources": [
      { "Source": "bbc-news", "Url": "http://feeds.bbci.co.uk/news/rss.xml" },
      { "Source": "bbc-tech", "Url": "http://feeds.bbci.co.uk/news/technology/rss.xml" }
    ]
  },
  "Scheduling": {
    "PollInterval": "00:05:00",
    "DispatchInterval": "00:00:15",
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
